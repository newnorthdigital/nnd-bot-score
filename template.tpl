// Signal weights. Datacenter alone meets the default 70 threshold; every other
// signal corroborates (a residential IP needs several integrity failures to
// cross 70). Tune here, not in the UI, so scores stay comparable across
// containers.
const W_DATACENTER = 70;        // primary    — client IP in a cloud/hosting range
const W_HEADLESS = 40;          // high       — automation/library/empty UA
const W_NO_CLIENT_HINTS = 25;   // medium     — modern-Chromium UA, no sec-ch-ua
const W_PLATFORM_MISMATCH = 25; // medium     — sec-ch-ua-platform vs UA OS
const W_MOBILE_MISMATCH = 20;   // medium     — sec-ch-ua-mobile vs UA mobile token
const W_BRAND_MISMATCH = 20;    // medium     — sec-ch-ua brand list is forged
const W_NO_ACCEPT_LANG = 15;    // medium     — browser UA, no accept-language
const W_NO_ACCEPT_ENCODING = 15;// medium     — browser UA, no accept-encoding
const W_OUTDATED_BROWSER = 10;  // low        — implausibly old Chromium major
const W_GEO_OUT_OF_MARKET = 10; // low (nudge)— datacenter IP outside the market
const W_GEO_HIGH_RISK = 10;     // low (nudge)— country on the high-risk list

const CHROMIUM_MIN_MAJOR = 80;
const GEO_HEADERS = ['cf-ipcountry','x-vercel-ip-country','cloudfront-viewer-country','x-appengine-country','x-geo-country','x-country-code'];

const debug = data.debug === true;
const log = (msg) => { if (debug) logToConsole('NND Bot Score - ' + msg); };

const isNum = (n) => getType(n) === 'number' && n === n;
const str = (s) => (getType(s) === 'string' ? s : '');
const lower = (s) => str(s).toLowerCase();
const numOr = (v, d) => { const n = makeNumber(v); return isNum(n) ? n : d; };
const header = (h) => str(getRequestHeader(h));

// Client IP: prefer the GA4 client's ip_override, then the first
// X-Forwarded-For hop (a fronting proxy/CDN otherwise makes every visitor look
// like one IP), then the raw socket address.
const resolveIp = () => {
  const ipo = getEventData('ip_override');
  if (getType(ipo) === 'string' && ipo) return ipo;
  const xff = header('x-forwarded-for');
  if (xff) { const first = xff.split(',')[0]; if (first) return first.split(' ').join(''); }
