// IPv4 dotted-quad to integer. Returns -1 for anything non-v4 (IPv6 falls
// through to the header/UA signals only — see NOTES).
const ipv4ToInt = (ip) => {
  const parts = ip.split('.');
  if (parts.length !== 4) return -1;
  let n = 0; let ok = true;
  parts.forEach((part) => {
    const o = makeNumber(part);
    if (!isNum(o) || o < 0 || o > 255) ok = false; else n = n * 256 + o;
  });
  return ok ? n : -1;
};

// Binary search the sorted [start,end] ranges. No bitwise ops in the sandbox,
// so IP math is plain arithmetic (max 2^32 is within Number's safe range).
const inRanges = (n, ranges) => {
  if (n < 0) return false;
  let lo = 0; let hi = ranges.length - 1; let found = false;
  while (lo <= hi && !found) {
    const mid = Math.floor((lo + hi) / 2); const r = ranges[mid];
    if (n < r[0]) hi = mid - 1; else if (n > r[1]) lo = mid + 1; else found = true;
