___TEMPLATE_PARAMETERS___

[
  {
    "type": "LABEL",
    "name": "intro",
    "displayName": "Returns a 0-100 bot score (higher = more bot-like) or a boolean. Run in <strong>score</strong> mode first to observe the distribution on real traffic before you wire it as a blocking-trigger exception."
  },
  {
    "type": "SELECT",
    "name": "outputMode",
    "displayName": "Output",
    "macrosInSelect": false,
    "selectItems": [
      { "value": "score", "displayValue": "Score (0-100 integer)" },
      { "value": "boolean", "displayValue": "Boolean (true when score >= threshold)" }
    ],
    "simpleValueType": true,
    "defaultValue": "score"
  },
  {
    "type": "TEXT",
    "name": "threshold",
    "displayName": "Block threshold",
    "simpleValueType": true,
    "defaultValue": 70,
    "help": "Score at or above which the visitor counts as a bot. Used directly in boolean mode; in score mode it is just the recommended cut-off for your blocking trigger. A datacenter IP alone scores 70.",
    "valueValidators": [
      { "type": "NON_EMPTY" },
      { "type": "REGEX", "args": ["^\\d{1,3}$"], "errorMessage": "Enter a number 0-100." }
    ]
  },
  {
    "type": "CHECKBOX",
    "name": "blockAiCrawlers",
    "checkboxText": "Count verified AI crawlers as bots",
    "simpleValueType": true,
    "defaultValue": false,
    "help": "Off (default): verified AI crawlers (GPTBot, ChatGPT-User, Googlebot, ...) score 0 and are never blocked. On: they score above the threshold so they are excluded from GA4. \"Verified\" means the UA matches a known crawler AND the IP is in that crawler's published range, so a spoofed crawler UA is still scored normally."
  },
  {
    "type": "GROUP",
    "name": "geoGroup",
    "displayName": "Location (optional)",
    "groupStyle": "ZIPPY_OPEN_ON_PARAM",
    "subParams": [
      {
        "type": "TEXT",
        "name": "geoHeader",
        "displayName": "Country header override",
        "simpleValueType": true,
        "valueHint": "cf-ipcountry",
        "help": "Request header carrying a 2-letter country code. Leave empty to auto-detect common ones (cf-ipcountry, x-vercel-ip-country, cloudfront-viewer-country, x-appengine-country, x-geo-country, x-country-code)."
      },
      {
        "type": "TEXT",
        "name": "inMarketRegions",
        "displayName": "In-market countries",
        "simpleValueType": true,
        "valueHint": "NL,BE,DE",
        "help": "Comma-separated 2-letter codes for the client's real markets. A datacenter IP geolocating OUTSIDE these gets a small nudge; in-market traffic is never penalised."
      },
      {
        "type": "TEXT",
        "name": "highRiskRegions",
        "displayName": "High-risk countries",
        "simpleValueType": true,
        "valueHint": "CN,RU",
        "help": "Optional comma-separated 2-letter codes that add a small score nudge regardless of IP type. Score-only, never a hard block."
      }
    ]
  },
  {
    "type": "CHECKBOX",
    "name": "debug",
    "checkboxText": "Log the score and reasons to console (debug/preview only)",
    "simpleValueType": true,
    "defaultValue": false
  }
